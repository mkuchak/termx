{
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "requireCleanWorkingDir": true,
    "requireUpstream": true,
    "push": true
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false,
    "tokenRef": "GITHUB_TOKEN"
  },
  "hooks": {
    "before:init": "if [ -t 0 ]; then printf '\\n\\u26A0  Have you walked through docs/PRE_RELEASE_CHECKLIST.md on the latest debug APK?\\n    Press Enter to continue or Ctrl+C to abort.\\n' && read _ || exit 1; else printf '\\n\\u26A0  Skipping checklist prompt (non-interactive shell)\\n'; fi",
    "after:bump": "echo \"Pushing tag triggers CI — android-release.yml will build, sign, create GitHub Release with the APK.\""
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          { "type": "feat", "section": "Features" },
          { "type": "fix", "section": "Bug Fixes" },
          { "type": "perf", "section": "Performance" },
          { "type": "refactor", "section": "Refactoring" },
          { "type": "chore", "hidden": true },
          { "type": "docs", "hidden": true },
          { "type": "style", "hidden": true },
          { "type": "test", "hidden": true },
          { "type": "ci", "hidden": true },
          { "type": "build", "hidden": true }
        ]
      },
      "infile": "CHANGELOG.md"
    }
  }
}
